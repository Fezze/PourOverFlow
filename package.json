{
  "name": "pouroverflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PourOverFlow Zepp OS scaffold",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "scripts": {
    "build": "zeus build",
    "test": "node node_modules/vitest/vitest.mjs run --config test/vitest.config.ts",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --config test/vitest.config.ts --coverage",
    "test:playwright": "node scripts/playwright-simulator-coverage.mjs",
    "test:playwright:harness": "node scripts/playwright-simulator-coverage.mjs --module-harness",
    "test:playwright:coverage:harness": "node scripts/playwright-simulator-coverage.mjs --module-harness --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "playwright-core": "^1.58.2",
    "v8-to-istanbul": "^9.3.0",
    "vitest": "^4.1.1"
  }
}
